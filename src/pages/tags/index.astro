---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))].sort();
---

<Layout title="Tagit" description="Kaikki blogin aiheet ja tagit.">
  <section class="max-w-2xl mx-auto">
    <h1 class="text-4xl font-bold mb-4">Tagit</h1>
    <p class="text-neutral-400 mb-12">Kaikki aiheet, joita blogissa käsitellään.</p>

    <div class="flex flex-wrap gap-3">
      {allTags.map((tag) => (
        <span class="px-4 py-2 bg-neutral-800 rounded-full text-sm">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-neutral-800">
      <a href="/" class="text-neutral-400 hover:text-neutral-200 transition-colors">
        ← Takaisin blogiin
      </a>
    </div>
  </section>
</Layout>