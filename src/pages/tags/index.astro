---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))].sort();
---

<Layout title="Tagit" description="Kaikki blogin aiheet ja tagit.">
  <section class="max-w-2xl mx-auto">
    <h1 class="font-serif text-4xl font-bold mb-4">Tagit</h1>
    <p class="text-lg mb-12" style="color: var(--color-text-muted)">Kaikki aiheet, joita blogissa käsitellään.</p>

    <div class="tags-grid flex flex-wrap gap-3">
      {allTags.map((tag) => (
        <span class="text-sm px-4 py-2 rounded-full cursor-default">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t" style="border-color: var(--color-border)">
      <a href="/" class="text-sm font-mono hover:opacity-80 transition-opacity">
        ← Takaisin blogiin
      </a>
    </div>
  </section>
</Layout>