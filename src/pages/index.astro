---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function getSlug(id: string) {
  return id.replace(/\.mdx?$/, '');
}
---

<Layout title="Blogi">
  <section>
    <h1 class="font-serif text-5xl font-bold mb-4">Blogi</h1>
    <p class="text-lg mb-12" style="color: var(--color-text-muted)">Ajatuksia yhteiskunnasta, hyvinvoinnista ja elämästä.</p>

    <div class="space-y-12">
      {posts.map((post) => (
        <article class="border-b pb-12 last:border-0 last:pb-0">
          <a href={`/blog/${getSlug(post.id)}/`} class="group block">
            <h2 class="font-serif text-3xl font-semibold mb-3 group-hover:opacity-80 transition-opacity">
              {post.data.title}
            </h2>
            <p class="mb-4 leading-relaxed">
              {post.data.description}
            </p>
            <div class="flex items-center gap-4 text-sm font-mono">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('fi-FI', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="flex gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="tag text-xs px-2 py-1 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>